# Copy to .env and fill in. All of these are required in production.

# Neon Postgres connection string (use a `dev` branch locally).
DATABASE_URL=

# Better Auth: random 32+ char secret (e.g. `openssl rand -base64 32`)
# and the app's public origin.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://coursible.dev

# Google OAuth (console.cloud.google.com → Credentials).
# Authorized redirect URI: <origin>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (magic-link email). Free tier is fine.
RESEND_API_KEY=
# Optional: verified sender. Defaults to Resend's onboarding address.
EMAIL_FROM=Coursible <signin@coursible.dev>

# LLM provider for course generation + open-ended grading:
# "kimi" (default, Kimi K2.6 via api.moonshot.ai) or "anthropic" (Opus/Haiku).
GENERATION_PROVIDER=kimi

# Kimi (Moonshot AI) API key — platform.kimi.ai → API Keys.
MOONSHOT_API_KEY=

# Anthropic API key — only needed when GENERATION_PROVIDER=anthropic.
# ANTHROPIC_API_KEY=

# Optional model overrides (defaults: kimi-k2.6 / claude-opus-4-8 generation,
# kimi-k2.6 / claude-haiku-4-5 grading).
# GENERATION_MODEL=
# GRADING_MODEL=
